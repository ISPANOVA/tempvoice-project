# ============================================
# TempVoice — Environment Variables (خدمة واحدة موحّدة)
# انسخ هذا الملف باسم .env في جذر المشروع محليًا،
# أو أضف نفس المتغيرات في Railway > Variables
# ============================================

# ---------- Discord Bot ----------

# توكن البوت من Discord Developer Portal (Bot > Token)
DISCORD_TOKEN=your_bot_token_here

# Client ID بتاع التطبيق (نفس قيمة DISCORD_CLIENT_ID تحت بالضبط)
CLIENT_ID=your_application_client_id_here

# ---------- قاعدة البيانات ----------

# رابط الاتصال الكامل بقاعدة بيانات PostgreSQL
# على Railway: استخدم خاصية "Add Reference" لربطها بخدمة Postgres تلقائيًا
DATABASE_URL=postgresql://user:password@host:port/database

# ---------- الداشبورد (Discord OAuth2) ----------

# مفتاح سري طويل وعشوائي لتوقيع جلسات تسجيل الدخول (JWT)
# يمكن توليده بالأمر: openssl rand -base64 32
SESSION_SECRET=generate_a_long_random_string_here

# بيانات تطبيق ديسكورد من https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_application_client_id_here
DISCORD_CLIENT_SECRET=your_application_client_secret

# رابط الاستدعاء بعد تسجيل الدخول - يجب أن يكون مطابقًا تمامًا
# لما هو مسجل في Discord Developer Portal > OAuth2 > Redirects
# مثال للتطوير المحلي: http://localhost:3000/api/auth/callback
# مثال للإنتاج على Railway: https://your-app.up.railway.app/api/auth/callback
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# رابط دعوة البوت لإضافته لسيرفر ديسكورد جديد (يظهر في الداشبورد كزر "Add to Discord")
NEXT_PUBLIC_BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=YOUR_CLIENT_ID&permissions=8&scope=bot%20applications.commands

# ---------- إعدادات التشغيل ----------

# البورت الذي يعمل عليه الخادم الموحّد (Railway يوفره تلقائيًا، اتركه كما هو)
PORT=3000
